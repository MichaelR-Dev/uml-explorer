{
  "name": "uml-explorer",
  "displayName": "UML Explorer",
  "description": "Explore your classes by UML relationships and dependencies.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:ts"
  ],
  "main": "./dist/extension.js",
  "author": {
    "name": "michaelr-dev"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "UMLExplorerSidebar", 
          "title": "UML Explorer", 
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "UMLExplorerSidebar": [
        {
          "id": "UMLExplorerView",
          "icon": "resources/icon.svg",
          "name": "UML Explorer",
          "type": "webview"
        }
      ]
    },
    "languages": [
      {
        "id": "ts",
        "extensions": [
          ".ts",
          ".tsx"
        ],
        "aliases": [
          "ts",
          "typescript"
        ]
      }
    ],
    "commands": [
      {
        "command": "uml-explorer.analyzeDependencies",
        "title": "UML Explorer: Analyze TypeScript Dependencies"
      },
      {
        "command": "uml-explorer.openUMLExplorerOnNode",
        "title": "UML Explorer: Open UML Explorer On Node"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "uml-explorer.openUMLExplorerOnNode",
          "when": "editorLangId == ts",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "uml-explorer.openUMLExplorerOnNode",
          "when": "resourceExtname == .ts || resourceExtname == .tsx",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
